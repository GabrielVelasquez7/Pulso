{
  "version": 2,
  "buildCommand": "bun run build && cp -r dist/server api/dist-server",
  "installCommand": "bun install",
  "framework": null,
  "outputDirectory": "dist/client",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/server"
    }
  ],
  "functions": {
    "api/server.js": {
      "includeFiles": "api/dist-server/**"
    }
  }
}